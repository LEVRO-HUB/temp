generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Employee {
  id            Int      @id @default(autoincrement())
  name          String
  mobile_number String   @unique
  email         String   @unique
  role          String   // backward compatibility
  password_hash String
  is_active     Boolean  @default(true)
  login_enabled Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  created_by    Int?     // refers to Employee.id
  
  role_id       Int?
  dept_id       Int?
  
  role_master   RoleMaster?   @relation(fields: [role_id], references: [id])
  dept_master   DepartmentMaster? @relation(fields: [dept_id], references: [id])

  enquiries     Enquiry[]
  bookings      Booking[]
  purchaseOrders PurchaseOrder[]
  payments      Payment[] @relation("PaymentsCreatedBy")
  paymentsUpdated Payment[] @relation("PaymentsUpdatedBy")
}

model RoleMaster {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  icon       String?  // Lucide icon name
  employees  Employee[]
  created_at DateTime @default(now())
}

model DepartmentMaster {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  icon       String?  // Lucide icon name
  employees  Employee[]
  created_at DateTime @default(now())
}

model Zone {
  id         Int      @id @default(autoincrement())
  zone_code  String?  @unique
  zone_name  String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by Int?     // Employee.id

  sites Site[]
}

model Site {
  id            Int      @id @default(autoincrement())
  site_name     String
  location      String
  zone_id       Int
  site_type     String   // hotel, service_apartment
  total_rooms   Int
  flat_number   String   // CR-01, CR-02 etc.
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  created_by    Int?

  zone Zone @relation(fields: [zone_id], references: [id])
  rooms Room[]
  enquiries Enquiry[]
  bookings Booking[]
  payments Payment[]
  purchaseOrders PurchaseOrder[]
}

model Room {
  id          Int      @id @default(autoincrement())
  site_id     Int
  room_number String   // CR-01, A-203
  room_type   String   // Room, 1BHK, 2BHK, 3BHK
  status      String   @default("available") // available, occupied, maintenance
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  site Site @relation(fields: [site_id], references: [id])
  bookings Booking[]
}

model Enquiry {
  id                Int      @id @default(autoincrement())
  enquiry_time      DateTime @default(now())
  guest_name        String
  mobile_number     String
  place             String?
  site_id           Int
  room_type_requested String
  check_in_date     DateTime
  check_out_date    DateTime?
  no_of_days        Int
  enquiry_source    String   // Phone Call, Walk-in, Online Platforms, Referral
  status            String   @default("new") // new, follow-up, converted, lost
  remarks           String?
  created_by        Int
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  employee Employee @relation(fields: [created_by], references: [id])
  site Site @relation(fields: [site_id], references: [id])
  bookings Booking[]
}

model Booking {
  id             Int      @id @default(autoincrement())
  enquiry_id     Int?
  site_id        Int
  room_id        Int
  booking_type   String   // walk-in, online, agent
  guest_name     String
  guest_count    Int
  mobile_number  String
  place          String?
  check_in_date  DateTime
  check_out_date DateTime
  total_nights   Int
  booking_date   DateTime @default(now())
  total_amount   Float
  created_by     Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  employee Employee @relation(fields: [created_by], references: [id])
  enquiry Enquiry? @relation(fields: [enquiry_id], references: [id])
  site Site @relation(fields: [site_id], references: [id])
  room Room @relation(fields: [room_id], references: [id])
  payments Payment[]
}

model Payment {
  id                  Int      @id @default(autoincrement())
  payment_date        DateTime @default(now())
  payment_no          String   @unique
  transaction_type    String
  type_of_method      String   // cash, UPI, bank, card
  payment_type        String   // advance, full, partial
  cheque_no           String?
  cheque_date         DateTime?
  rtgs_ref_no         String?
  currency_code       String   @default("INR")
  ex_rate             Float    @default(1.0)
  ex_rate_factors     String?
  remarks             String?
  sub_total_in_forex  Float
  tax_amt_in_forex    Float
  payment_amt_in_forex Float
  payment_amt_in_base Float
  active              Boolean  @default(true)
  
  site_id             Int
  booking_id          Int
  vendor_details_id   Int?
  bank_id             Int?
  cc_bank_id          Int?
  currencies_id       Int?

  created_by_id       Int
  updated_by_id       Int?
  inserted_at         DateTime @default(now())
  updated_at          DateTime @updatedAt

  site Site @relation(fields: [site_id], references: [id])
  booking Booking @relation(fields: [booking_id], references: [id])
  createdBy Employee @relation("PaymentsCreatedBy", fields: [created_by_id], references: [id])
  updatedBy Employee? @relation("PaymentsUpdatedBy", fields: [updated_by_id], references: [id])
}

model PurchaseOrder {
  id                Int      @id @default(autoincrement())
  po_number         String   @unique
  vendor_name       String
  date              DateTime @default(now())
  site_id           Int
  department        String?
  priority          String   @default("Normal") // Normal, Urgent, Low
  payment_terms     String?
  expected_delivery DateTime?
  delivery_location String?
  contact_person    String?
  remarks           String?
  
  subtotal          Float    @default(0)
  tax_amount        Float    @default(0)
  total_amount      Float    @default(0)
  
  flag              Int      @default(0) // 0: Pending, 1: Approved, 2: Rejected, 3: Draft
  
  created_by        Int
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  employee Employee @relation(fields: [created_by], references: [id])
  site     Site     @relation(fields: [site_id], references: [id])
  items    PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               Int      @id @default(autoincrement())
  purchase_order_id Int
  description      String
  unit             String?
  quantity         Int
  unit_price       Float
  total_price      Float

  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade)
}
